// Package app tests explicit restart of stopped sealed workflows and batches.
package app

import (
	"bytes"
	"context"
	"encoding/json"
	"errors"
	"os"
	"path/filepath"
	"strings"
	"testing"
	"time"
)

type failingRestartRunner struct{}

// Run simulates an agent failure after restart has already reset the run.
func (failingRestartRunner) Run(context.Context, string, string, string, StageOptions) (string, error) {
	return "", errors.New("agent failed after restart")
}

// TestRestartRunDetachedResetsRecoverableState verifies restart reuses the same run.
func TestRestartRunDetachedResetsRecoverableState(t *testing.T) {
	repo := gitRepo(t)
	runID := "run-failed"
	state := State{
		RunID:      runID,
		ChangeName: "demo",
		Sealed:     true,
		Status:     statusFailed,
		Stage:      "execution",
		Error:      "network unavailable",
		Sessions:   map[string]string{"codex:executor": "thread-1"},
		Stages:     map[string]string{"execution": statusInterrupted},
		Paths:      map[string]string{"x": "y"},
		Workflow:   DefaultWorkflowConfig(),
	}
	if err := saveState(repo, state); err != nil {
		t.Fatal(err)
	}
	var started []string
	previous := startDetachedCommand
	startDetachedCommand = func(_ string, id string) error {
		started = append(started, id)
		return nil
	}
	t.Cleanup(func() { startDetachedCommand = previous })

	engine := NewEngine(repo, testRegistry(fakeRunner{}))
	if err := engine.RestartRunDetached(runID, true); err != nil {
		t.Fatal(err)
	}
	final, err := loadState(repo, runID)
	if err != nil {
		t.Fatal(err)
	}
	if final.Status != statusRunning || final.Error != "" || final.RunID != runID || final.Sessions["codex:executor"] != "thread-1" || final.Paths["x"] != "y" {
		t.Fatalf("state = %#v, want same run reset to running", final)
	}
	if len(started) != 1 || started[0] != runID {
		t.Fatalf("started = %v, want %s", started, runID)
	}
}

// TestRestartRunDetachedResetsInterruptedAndRunningStates verifies Restart covers interrupted and running run states.
func TestRestartRunDetachedResetsInterruptedAndRunningStates(t *testing.T) {
	for _, tc := range []struct {
		name      string
		status    string
		stage     string
		wantStage string
	}{
		{name: "interrupted", status: statusInterrupted, stage: statusInterrupted, wantStage: "execution"},
		{name: "running", status: statusRunning, stage: "review_1", wantStage: "review_1"},
		{name: "acceptance-contract", status: statusAcceptanceContractBlocked, stage: statusAcceptanceContractBlocked, wantStage: "execution"},
	} {
		t.Run(tc.name, func(t *testing.T) {
			repo := gitRepo(t)
			runID := "run-" + tc.name
			state := State{
				RunID:      runID,
				ChangeName: "demo",
				Sealed:     true,
				Status:     tc.status,
				Stage:      tc.stage,
				Error:      "previous error",
				Workflow:   DefaultWorkflowConfig(),
			}
			if err := saveState(repo, state); err != nil {
				t.Fatal(err)
			}
			var started []string
			previous := startDetachedCommand
			startDetachedCommand = func(_ string, id string) error {
				started = append(started, id)
				return nil
			}
			t.Cleanup(func() { startDetachedCommand = previous })

			engine := NewEngine(repo, testRegistry(fakeRunner{}))
			if err := engine.RestartRunDetached(runID, true); err != nil {
				t.Fatal(err)
			}
			final, err := loadState(repo, runID)
			if err != nil {
				t.Fatal(err)
			}
			if final.Status != statusRunning || final.Stage != tc.wantStage || final.Error != "" {
				t.Fatalf("state = %#v, want running/%s with cleared error", final, tc.wantStage)
			}
			if len(started) != 1 || started[0] != runID {
				t.Fatalf("started = %v, want %s", started, runID)
			}
		})
	}
}

// TestRestartRunRejectsTerminalAndActiveLock verifies unsafe run restarts are refused.
func TestRestartRunRejectsTerminalAndActiveLock(t *testing.T) {
	repo := gitRepo(t)
	engine := NewEngine(repo, testRegistry(fakeRunner{}))
	for _, status := range []string{statusDone, statusBlocked, statusValidationBlocked, statusAborted, "aborted"} {
		runID := "run-" + status
		state := State{RunID: runID, ChangeName: "demo", Sealed: true, Status: status, Stage: status, Workflow: DefaultWorkflowConfig()}
		if err := saveState(repo, state); err != nil {
			t.Fatal(err)
		}
		if err := engine.RestartRunDetached(runID, true); err == nil {
			t.Fatalf("RestartRunDetached(%s) succeeded, want rejection", status)
		}
	}

	runID := "run-locked"
	state := State{RunID: runID, ChangeName: "demo", Sealed: true, Status: statusFailed, Stage: "execution", Workflow: DefaultWorkflowConfig()}
	if err := saveState(repo, state); err != nil {
		t.Fatal(err)
	}
	lock := LockInfo{PID: os.Getpid(), RunID: runID, StartedAt: time.Now().UTC().Format(time.RFC3339Nano)}
	data, _ := json.Marshal(lock)
	if err := os.WriteFile(filepath.Join(runDir(repo, runID), "lock"), append(data, '\n'), 0o644); err != nil {
		t.Fatal(err)
	}
	if err := engine.RestartRunDetached(runID, true); err == nil || !strings.Contains(err.Error(), "正被存活进程锁定") {
		t.Fatalf("active lock err = %v", err)
	}
}

// TestRestartRunJSONPersistsFailedState verifies inline restart failures do not leave runs running.
func TestRestartRunJSONPersistsFailedState(t *testing.T) {
	repo := gitRepo(t)
	runID := "run-json-failed"
	if err := os.MkdirAll(filepath.Join(repo, "docs", "changes", "1-演示"), 0o755); err != nil {
		t.Fatal(err)
	}
	head, diff, err := gitSnapshot(repo)
	if err != nil {
		t.Fatal(err)
	}
	state := State{
		RunID:        runID,
		ChangeName:   "1-演示",
		Sealed:       true,
		Status:       statusFailed,
		Stage:        "execution",
		BaselineHead: head,
		BaselineDiff: diff,
		Workflow:     DefaultWorkflowConfig(),
	}
	if err := saveState(repo, state); err != nil {
		t.Fatal(err)
	}
	mustWritePrompt(t, filepath.Join(runDir(repo, runID), "prompt-snapshot.yaml"), "prompts:\n  execution: \"execution\\n\"\n")
	engine := NewEngine(repo, testRegistry(failingRestartRunner{}))
	var stdout bytes.Buffer

	err = engine.RestartRunJSON(context.Background(), runID, &stdout)
	if err == nil {
		t.Fatal("RestartRunJSON succeeded, want agent failure")
	}
	final, loadErr := loadState(repo, runID)
	if loadErr != nil {
		t.Fatal(loadErr)
	}
	if final.Status != statusFailed || !strings.Contains(final.Error, "agent failed after restart") {
		t.Fatalf("state = %#v, want failed state with agent error", final)
	}
	lines := strings.Split(strings.TrimSpace(stdout.String()), "\n")
	if len(lines) < 2 {
		t.Fatalf("stdout = %q, want running and failed DTOs", stdout.String())
	}
	var dto RunnerState
	if err := json.Unmarshal([]byte(lines[len(lines)-1]), &dto); err != nil {
		t.Fatal(err)
	}
	if dto.Status != statusFailed || !strings.Contains(dto.Error, "agent failed after restart") {
		t.Fatalf("last DTO = %#v, want failed restart error", dto)
	}
}

// TestRestartBatchResetsCurrentRunAndBatch verifies failed batches continue from the same run.
func TestRestartBatchResetsCurrentRunAndBatch(t *testing.T) {
	repo := gitRepo(t)
	runID := "run-current"
	state := State{RunID: runID, ChangeName: "1-a", Sealed: true, Status: statusFailed, Stage: "execution", BatchID: "batch-1", Workflow: DefaultWorkflowConfig()}
	if err := saveState(repo, state); err != nil {
		t.Fatal(err)
	}
	batch := BatchState{
		BatchID:      "batch-1",
		Status:       batchStatusFailed,
		Changes:      []string{"1-a", "2-b"},
		CurrentIndex: 0,
		RunIDs:       map[string]string{"1-a": runID},
		FailedChange: "1-a",
		FailedRunID:  runID,
		Error:        "failed",
	}
	if err := saveBatchState(repo, batch); err != nil {
		t.Fatal(err)
	}
	var started []string
	previous := startDetachedBatchCommand
	startDetachedBatchCommand = func(_ string, id string) error {
		started = append(started, id)
		return nil
	}
	t.Cleanup(func() { startDetachedBatchCommand = previous })

	engine := NewEngine(repo, testRegistry(fakeRunner{}))
	if err := engine.RestartBatchDetached("batch-1"); err != nil {
		t.Fatal(err)
	}
	finalBatch, _ := loadBatchState(repo, "batch-1")
	finalRun, _ := loadState(repo, runID)
	if finalBatch.Status != batchStatusRunning || finalBatch.FailedChange != "" || finalBatch.FailedRunID != "" || finalBatch.Error != "" {
		t.Fatalf("batch = %#v, want cleared running batch", finalBatch)
	}
	// Old run association should be cleared so batch worker creates a fresh run.
	if finalBatch.RunIDs["1-a"] != "" {
		t.Fatalf("batch RunIDs[1-a] = %q, want empty (cleared for fresh run creation)", finalBatch.RunIDs["1-a"])
	}
	// Old run should remain failed, not reused.
	if finalRun.Status == statusRunning {
		t.Fatalf("run status = %s, old run should not be reused after batch restart", finalRun.Status)
	}
	if len(started) != 1 || started[0] != "batch-1" {
		t.Fatalf("started = %v, want batch-1", started)
	}
}

// TestRestartRunningBatchStartsWorker verifies running queues can be nudged without mutation.
func TestRestartRunningBatchStartsWorker(t *testing.T) {
	repo := gitRepo(t)
	batch := BatchState{BatchID: "batch-running", Status: batchStatusRunning, Changes: []string{"1-a"}, RunIDs: map[string]string{}}
	if err := saveBatchState(repo, batch); err != nil {
		t.Fatal(err)
	}
	var started []string
	previous := startDetachedBatchCommand
	startDetachedBatchCommand = func(_ string, id string) error {
		started = append(started, id)
		return nil
	}
	t.Cleanup(func() { startDetachedBatchCommand = previous })

	engine := NewEngine(repo, testRegistry(fakeRunner{}))
	if err := engine.RestartBatchDetached("batch-running"); err != nil {
		t.Fatal(err)
	}
	final, err := loadBatchState(repo, "batch-running")
	if err != nil {
		t.Fatal(err)
	}
	if final.Status != batchStatusRunning || final.CurrentIndex != 0 || strings.Join(final.Changes, ",") != "1-a" {
		t.Fatalf("batch = %#v, want unchanged running queue", final)
	}
	if len(started) != 1 || started[0] != "batch-running" {
		t.Fatalf("started = %v, want batch-running", started)
	}
}

// TestRestartBatchRejectsTerminalAndBlockedCurrentRun covers non-restartable batch states.
func TestRestartBatchRejectsTerminalAndBlockedCurrentRun(t *testing.T) {
	for _, status := range []string{batchStatusDone, batchStatusAborted} {
		t.Run(status, func(t *testing.T) {
			repo := gitRepo(t)
			batchID := "batch-" + status
			batch := BatchState{BatchID: batchID, Status: status, Changes: []string{"1-a"}, CurrentIndex: 0, RunIDs: map[string]string{}}
			if err := saveBatchState(repo, batch); err != nil {
				t.Fatal(err)
			}
			engine := NewEngine(repo, testRegistry(fakeRunner{}))
			if err := engine.RestartBatchDetached(batchID); err == nil {
				t.Fatalf("RestartBatchDetached(%s) succeeded, want rejection", status)
			}
			final, err := loadBatchState(repo, batchID)
			if err != nil {
				t.Fatal(err)
			}
			if final.Status != status {
				t.Fatalf("batch status = %s, want %s", final.Status, status)
			}
		})
	}

	for _, runStatus := range []string{statusBlocked, statusValidationBlocked, statusAborted} {
		t.Run("current-run-"+runStatus, func(t *testing.T) {
			repo := gitRepo(t)
			runID := "run-" + runStatus
			batchID := "batch-" + runStatus
			state := State{RunID: runID, ChangeName: "1-a", Sealed: true, Status: runStatus, Stage: runStatus, BatchID: batchID, Workflow: DefaultWorkflowConfig()}
			if err := saveState(repo, state); err != nil {
				t.Fatal(err)
			}
			batch := BatchState{
				BatchID:      batchID,
				Status:       batchStatusFailed,
				Changes:      []string{"1-a"},
				CurrentIndex: 0,
				RunIDs:       map[string]string{"1-a": runID},
				FailedChange: "1-a",
				FailedRunID:  runID,
				Error:        "failed",
			}
			if err := saveBatchState(repo, batch); err != nil {
				t.Fatal(err)
			}
			engine := NewEngine(repo, testRegistry(fakeRunner{}))
			if err := engine.RestartBatchDetached(batchID); err == nil {
				t.Fatalf("RestartBatchDetached with current run %s succeeded, want rejection", runStatus)
			}
			final, err := loadBatchState(repo, batchID)
			if err != nil {
				t.Fatal(err)
			}
			if final.Status != batchStatusFailed || final.FailedRunID != runID || final.Error == "" {
				t.Fatalf("batch = %#v, want failed batch preserved", final)
			}
		})
	}
}

// TestRestartBatchRejectsFailedBatchWithMissingRunState verifies restart rejects missing run state.
func TestRestartBatchRejectsFailedBatchWithMissingRunState(t *testing.T) {
	repo := gitRepo(t)
	batchID := "batch-missing-run"
	batch := BatchState{
		BatchID:      batchID,
		Status:       batchStatusFailed,
		Changes:      []string{"1-a"},
		CurrentIndex: 0,
		RunIDs:       map[string]string{"1-a": "run-missing"},
		FailedChange: "1-a",
		FailedRunID:  "run-missing",
		Error:        "failed",
	}
	if err := saveBatchState(repo, batch); err != nil {
		t.Fatal(err)
	}
	engine := NewEngine(repo, testRegistry(fakeRunner{}))
	err := engine.RestartBatchDetached(batchID)
	if err == nil {
		t.Fatal("RestartBatchDetached with missing run state succeeded, want rejection")
	}
	if !strings.Contains(err.Error(), "工作流记录缺失") {
		t.Fatalf("error = %v, want '工作流记录缺失'", err)
	}
	// Batch state must not be modified.
	final, err := loadBatchState(repo, batchID)
	if err != nil {
		t.Fatal(err)
	}
	if final.Status != batchStatusFailed {
		t.Fatalf("batch status = %s, want %s", final.Status, batchStatusFailed)
	}
	if final.FailedRunID != "run-missing" || final.FailedChange != "1-a" || final.Error != "failed" {
		t.Fatalf("batch state was modified despite rejection: %#v", final)
	}
	if len(final.RunIDs) == 0 || final.RunIDs["1-a"] != "run-missing" {
		t.Fatalf("run_ids should be preserved, got %v", final.RunIDs)
	}
}

// TestResolveRestartTargetSkipsActiveLockedRunningRun verifies default restart chooses recoverable work.
func TestResolveRestartTargetSkipsActiveLockedRunningRun(t *testing.T) {
	repo := gitRepo(t)
	lockedRun := "20260515T010000.000000000Z"
	failedRun := "20260515T000000.000000000Z"
	if err := saveState(repo, State{RunID: lockedRun, ChangeName: "new", Sealed: true, Status: statusRunning, Stage: "execution", Workflow: DefaultWorkflowConfig()}); err != nil {
		t.Fatal(err)
	}
	if err := saveState(repo, State{RunID: failedRun, ChangeName: "old", Sealed: true, Status: statusFailed, Stage: "execution", Workflow: DefaultWorkflowConfig()}); err != nil {
		t.Fatal(err)
	}
	mustWriteLock(t, repo, lockedRun, LockInfo{PID: os.Getpid(), RunID: lockedRun, StartedAt: time.Now().UTC().Format(time.RFC3339Nano)})

	kind, ref, err := ResolveRestartTarget(repo, nil)
	if err != nil {
		t.Fatal(err)
	}
	if kind != "run" || ref.ID != failedRun {
		t.Fatalf("target = %s %#v, want failed run after locked running run", kind, ref)
	}
}

// TestRestartCLIJSONRequiresExplicitID protects scripts from implicit target changes.
func TestRestartCLIJSONRequiresExplicitID(t *testing.T) {
	repo := gitRepo(t)
	t.Chdir(repo)
	var stdout bytes.Buffer
	err := Run([]string{"restart", "--json"}, strings.NewReader(""), &stdout, &bytes.Buffer{})
	if err == nil {
		t.Fatal("restart --json succeeded, want usage error")
	}
	if stdout.Len() != 0 {
		t.Fatalf("stdout = %q, want empty on usage error", stdout.String())
	}
}

// TestRunBatchRefusesFailedWithoutRestart keeps explicit restart as the only reset path.
func TestRunBatchRefusesFailedWithoutRestart(t *testing.T) {
	repo := gitRepo(t)
	batch := BatchState{BatchID: "batch-failed", Status: batchStatusFailed, Changes: []string{"1-a"}, RunIDs: map[string]string{}}
	if err := saveBatchState(repo, batch); err != nil {
		t.Fatal(err)
	}
	engine := NewEngine(repo, testRegistry(fakeRunner{}))
	if err := engine.RunBatch(context.Background(), "batch-failed"); err == nil {
		t.Fatal("RunBatch succeeded, want explicit restart error")
	}
}

// TestNodeRunSubagentReturnsMergeStateError verifies completion sessions are required state.
func TestNodeRunSubagentReturnsMergeStateError(t *testing.T) {
	repo := gitRepo(t)
	runID := "run-subagent-merge-error"
	workflow := DefaultWorkflowConfig()
	group := workflow.Parallel.Groups["implementation_context"]
	if len(group.Members) == 0 {
		t.Fatal("implementation_context group missing test member")
	}
	member := group.Members[0]
	state := State{
		RunID:      runID,
		ChangeName: "demo",
		Status:     statusRunning,
		Stage:      "execution",
		Sessions:   map[string]string{"codex:executor": "executor-session"},
		Workflow:   workflow,
	}
	if err := saveState(repo, state); err != nil {
		t.Fatal(err)
	}

	originalMerge := mergeSubagentSessionState
	mergeSubagentSessionState = func(string, string, func(*State)) error {
		return errors.New("state write failed")
	}
	defer func() { mergeSubagentSessionState = originalMerge }()

	engine := Engine{Repo: repo, Registry: testRegistry(fakeRunner{})}
	var stdout bytes.Buffer
	err := engine.nodeRunSubagent(context.Background(), state, []string{"--group", "implementation_context", "--member", member.Name, "--stage", "execution"}, &stdout)
	if err == nil || !strings.Contains(err.Error(), "record subagent session") {
		t.Fatalf("nodeRunSubagent error = %v, want record subagent session failure", err)
	}
	if strings.Contains(stdout.String(), `"status":"completed"`) {
		t.Fatalf("subagent node reported completed despite merge failure:\n%s", stdout.String())
	}

	latest, err := loadState(repo, runID)
	if err != nil {
		t.Fatal(err)
	}
	if latest.Status != statusFailed {
		t.Fatalf("state status = %q, want failed after session merge failure", latest.Status)
	}
	options, err := workflow.StageOption("execution")
	if err != nil {
		t.Fatal(err)
	}
	tool := options.Tool
	if member.Tool != "" {
		tool = member.Tool
	}
	key := sessionStateKey(tool, "subagent:implementation_context:"+member.Name+":0")
	if latest.Sessions[key] != "" {
		t.Fatalf("session %s persisted despite merge failure: %q", key, latest.Sessions[key])
	}
}

type subagentOptionsCaptureRunner struct {
	options StageOptions
	capture *artifactCapture
}

// SetArtifactCapture records where Run should emit final JSON instead of writing the artifact.
func (r *subagentOptionsCaptureRunner) SetArtifactCapture(capture *artifactCapture) {
	r.capture = capture
}

// Run records the options supplied to a subagent and writes a valid member artifact.
func (r *subagentOptionsCaptureRunner) Run(_ context.Context, _ string, prompt, _ string, options StageOptions) (string, error) {
	r.options = options
	output := promptValue(prompt, "SUBAGENT_OUTPUT")
	name := promptValue(prompt, "SUBAGENT_NAME")
	purpose := promptValue(prompt, "SUBAGENT_PURPOSE")
	changeName := promptValue(prompt, "CURRENT_CHANGE")
	body := `{"name":"` + name + `","change_name":"` + changeName + `","purpose":"` + purpose + `","status":"success","summary":"captured","evidence":["unit-test"]}` + "\n"
	if r.capture != nil {
		r.capture.Append(body)
		return "capture-session", nil
	}
	if err := os.MkdirAll(filepath.Dir(output), 0o755); err != nil {
		return "", err
	}
	return "capture-session", os.WriteFile(output, []byte(body), 0o644)
}

type subagentOptionsCaptureTool struct {
	runner AgentRunner
}

// Name returns the pi backend name so nodeRunSubagent applies read-only options.
func (t subagentOptionsCaptureTool) Name() string { return "pi" }

// Resolve keeps this unit test independent from a real pi binary.
func (t subagentOptionsCaptureTool) Resolve() error { return nil }

// PlanningCommand is unused by the sealed subagent node test.
func (t subagentOptionsCaptureTool) PlanningCommand(context.Context, string, string, io.Reader, StageOptions) (*exec.Cmd, error) {
	return nil, os.ErrInvalid
}

// NewRunner returns the capturing test runner.
func (t subagentOptionsCaptureTool) NewRunner() AgentRunner { return t.runner }

type subagentRetryCaptureRunner struct {
	attempts  int
	capture   *artifactCapture
	threadIDs []string
}

// SetArtifactCapture records the attempt-local capture sink for retry materialization.
func (r *subagentRetryCaptureRunner) SetArtifactCapture(capture *artifactCapture) {
	r.capture = capture
}

// Run emits a malformed captured artifact first, then repairs it in the resumed session.
func (r *subagentRetryCaptureRunner) Run(_ context.Context, _ string, prompt, threadID string, _ StageOptions) (string, error) {
	r.attempts++
	r.threadIDs = append(r.threadIDs, threadID)
	if r.capture == nil {
		return "", errors.New("missing artifact capture")
	}
	if r.attempts > 1 {
		if threadID != "capture-retry-session" {
			return "", fmt.Errorf("retry thread id = %q, want capture-retry-session", threadID)
		}
		if !strings.Contains(prompt, "evidence") || !strings.Contains(prompt, "必须是字符串") {
			return "", fmt.Errorf("retry prompt missing schema guidance:\n%s", prompt)
		}
	}
	name := promptValue(prompt, "SUBAGENT_NAME")
	purpose := promptValue(prompt, "SUBAGENT_PURPOSE")
	changeName := promptValue(prompt, "CURRENT_CHANGE")
	body := `{"name":"` + name + `","change_name":"` + changeName + `","purpose":"` + purpose + `","status":"success","summary":"first malformed capture","evidence":[{"source":"go.mod"}]}`
	if r.attempts > 1 {
		body = `{"name":"` + name + `","change_name":"` + changeName + `","purpose":"` + purpose + `","status":"success","summary":"captured retry repaired artifact","evidence":["go.mod: module github.com/xbugs221/oz"]}`
	}
	r.capture.Append(body + "\n")
	return "capture-retry-session", nil
}

type subagentCaptureAndSchemaRetryRunner struct {
	attempts int
	capture  *artifactCapture
	prompts  []string
}

// SetArtifactCapture records the attempt-local capture sink.
func (r *subagentCaptureAndSchemaRetryRunner) SetArtifactCapture(capture *artifactCapture) {
	r.capture = capture
}

// Run reproduces a real retry chain: uncaptured JSON, malformed evidence, then repaired JSON.
func (r *subagentCaptureAndSchemaRetryRunner) Run(_ context.Context, _ string, prompt, _ string, _ StageOptions) (string, error) {
	r.attempts++
	r.prompts = append(r.prompts, prompt)
	if r.capture == nil {
		return "", errors.New("missing artifact capture")
	}
	name := promptValue(prompt, "SUBAGENT_NAME")
	purpose := promptValue(prompt, "SUBAGENT_PURPOSE")
	changeName := promptValue(prompt, "CURRENT_CHANGE")
	switch r.attempts {
	case 1:
		r.capture.Append(`{"name":"` + name + `","change_name":"` + changeName + `","purpose":"` + purpose + `","status":0,"summary":"invalid quote","evidence":["line says "workspace""]}` + "\n")
	case 2:
		r.capture.Append(`{"name":"` + name + `","change_name":"` + changeName + `","purpose":"` + purpose + `","status":0,"summary":"object evidence","evidence":[{"file":"go.mod"}]}` + "\n")
	default:
		r.capture.Append(`{"name":"` + name + `","change_name":"` + changeName + `","purpose":"` + purpose + `","status":0,"summary":"repaired","evidence":["go.mod: module github.com/xbugs221/oz"]}` + "\n")
	}
	return "capture-schema-session", nil
}

// TestNodeRunSubagentForcesPiSandbox verifies parallel pi helpers cannot inherit write permissions.
func TestNodeRunSubagentForcesPiSandbox(t *testing.T) {
	repo := gitRepo(t)
	mustChange(t, repo, "demo")
	workflow := DefaultWorkflowConfig()
	workflow.Stages["execution"] = StageOptions{Tool: "codex", Permissions: "danger-full-access"}
	workflow.Parallel.Enabled = true
	workflow.Parallel.Groups = map[string]ParallelGroupConfig{
		"implementation_context": {
			Mode:    "advisory",
			Members: []ParallelMemberConfig{{Name: "代码库侦察员", Purpose: "汇总 execution 需要读取的文件和测试模式", Stage: "before_execution", Tool: "pi"}},
		},
	}
	state := State{
		RunID:      "run-subagent-sandbox",
		ChangeName: "demo",
		Status:     statusRunning,
		Stage:      "execution",
		Sessions:   map[string]string{},
		Workflow:   workflow,
	}
	if err := saveState(repo, state); err != nil {
		t.Fatal(err)
	}
	runner := &subagentOptionsCaptureRunner{}
	registry := &AgentRegistry{}
	registry.Register(subagentOptionsCaptureTool{runner: runner})
	engine := Engine{Repo: repo, Registry: registry}
	var stdout bytes.Buffer
	err := engine.nodeRunSubagent(context.Background(), state, []string{"--group", "implementation_context", "--member", "代码库侦察员", "--stage", "execution"}, &stdout)
	if err != nil {
		t.Fatal(err)
	}
	if runner.options.Permissions != "sandbox" {
		t.Fatalf("subagent permissions = %q, want sandbox", runner.options.Permissions)
	}
	path := memberArtifactPath(repo, state.RunID, "implementation_context", 0, "代码库侦察员")
	if !fileExists(path) {
		t.Fatalf("captured stdout artifact was not materialized at %s", path)
	}
}

// TestNodeRunSubagentReplacesCapturedInvalidArtifactOnRetry proves stdout artifacts are not pinned to the first bad capture.
func TestNodeRunSubagentReplacesCapturedInvalidArtifactOnRetry(t *testing.T) {
	repo := gitRepo(t)
	mustChange(t, repo, "demo")
	workflow := DefaultWorkflowConfig()
	workflow.Stages["execution"] = StageOptions{Tool: "codex"}
	workflow.Parallel.Enabled = true
	workflow.Parallel.Groups = map[string]ParallelGroupConfig{
		"implementation_context": {
			Mode:    "advisory",
			Members: []ParallelMemberConfig{{Name: "代码库侦察员", Purpose: "汇总 execution 需要读取的文件和测试模式", Stage: "before_execution", Tool: "pi"}},
		},
	}
	state := State{
		RunID:      "run-subagent-capture-retry",
		ChangeName: "demo",
		Status:     statusRunning,
		Stage:      "execution",
		Sessions:   map[string]string{},
		Workflow:   workflow,
	}
	if err := saveState(repo, state); err != nil {
		t.Fatal(err)
	}
	runner := &subagentRetryCaptureRunner{}
	registry := &AgentRegistry{}
	registry.Register(subagentOptionsCaptureTool{runner: runner})
	engine := Engine{Repo: repo, Registry: registry}
	var stdout bytes.Buffer
	err := engine.nodeRunSubagent(context.Background(), state, []string{"--group", "implementation_context", "--member", "代码库侦察员", "--stage", "execution"}, &stdout)
	if err != nil {
		t.Fatal(err)
	}
	if runner.attempts != 2 {
		t.Fatalf("attempts = %d, want 2", runner.attempts)
	}
	if len(runner.threadIDs) != 2 || runner.threadIDs[1] != "capture-retry-session" {
		t.Fatalf("thread ids = %#v, want retry to resume first session", runner.threadIDs)
	}
	path := memberArtifactPath(repo, state.RunID, "implementation_context", 0, "代码库侦察员")
	result, err := readMemberArtifact(path)
	if err != nil {
		t.Fatal(err)
	}
	if result.Summary != "captured retry repaired artifact" {
		t.Fatalf("artifact summary = %q, want repaired retry output", result.Summary)
	}
	if len(result.Evidence) != 1 || result.Evidence[0] != "go.mod: module github.com/xbugs221/oz" {
		t.Fatalf("artifact evidence = %#v, want repaired string evidence", result.Evidence)
	}
}

// TestNodeRunSubagentRetriesCaptureAndSchemaFailuresWithActionablePrompts prevents false no-such-file retry guidance.
func TestNodeRunSubagentRetriesCaptureAndSchemaFailuresWithActionablePrompts(t *testing.T) {
	repo := gitRepo(t)
	mustChange(t, repo, "demo")
	workflow := DefaultWorkflowConfig()
	workflow.Stages["execution"] = StageOptions{Tool: "codex"}
	workflow.Parallel.Enabled = true
	workflow.Parallel.Groups = map[string]ParallelGroupConfig{
		"implementation_context": {
			Mode:    "advisory",
			Members: []ParallelMemberConfig{{Name: "代码库侦察员", Purpose: "汇总 execution 需要读取的文件和测试模式", Stage: "before_execution", Tool: "pi"}},
		},
	}
	state := State{
		RunID:      "run-subagent-capture-schema-retry",
		ChangeName: "demo",
		Status:     statusRunning,
		Stage:      "execution",
		Sessions:   map[string]string{},
		Workflow:   workflow,
	}
	if err := saveState(repo, state); err != nil {
		t.Fatal(err)
	}
	runner := &subagentCaptureAndSchemaRetryRunner{}
	registry := &AgentRegistry{}
	registry.Register(subagentOptionsCaptureTool{runner: runner})
	engine := Engine{Repo: repo, Registry: registry}
	var stdout bytes.Buffer
	err := engine.nodeRunSubagent(context.Background(), state, []string{"--group", "implementation_context", "--member", "代码库侦察员", "--stage", "execution"}, &stdout)
	if err != nil {
		t.Fatal(err)
	}
	if runner.attempts != 3 {
		t.Fatalf("attempts = %d, want capture retry plus schema retry", runner.attempts)
	}
	if len(runner.prompts) != 3 {
		t.Fatalf("prompts = %d, want 3", len(runner.prompts))
	}
	if !strings.Contains(runner.prompts[1], "未从最终回复捕获到合法 SUBAGENT_OUTPUT JSON object") ||
		!strings.Contains(runner.prompts[1], "裸 JSON object") ||
		strings.Contains(runner.prompts[1], "no such file") {
		t.Fatalf("capture retry prompt is not actionable:\n%s", runner.prompts[1])
	}
	if !strings.Contains(runner.prompts[2], "evidence 第 1 项必须是字符串") ||
		!strings.Contains(runner.prompts[2], "evidence: string[]") {
		t.Fatalf("schema retry prompt missing evidence guidance:\n%s", runner.prompts[2])
	}
	path := memberArtifactPath(repo, state.RunID, "implementation_context", 0, "代码库侦察员")
	result, err := readMemberArtifact(path)
	if err != nil {
		t.Fatal(err)
	}
	if result.Summary != "repaired" || len(result.Evidence) != 1 || result.Evidence[0] != "go.mod: module github.com/xbugs221/oz" {
		t.Fatalf("artifact = %#v, want repaired output", result)
	}
}

// TestExtractCapturedMemberJSONObjectSkipsNestedObjects protects Pi text capture from report JSON fragments.
func TestExtractCapturedMemberJSONObjectSkipsNestedObjects(t *testing.T) {
	member := ParallelMemberConfig{Name: "代码库侦察员", Purpose: "汇总 execution 需要读取的文件和测试模式"}
	text := strings.Join([]string{
		"我先列出一个发现对象：",
		`{"title":"resolveWorkbenchPath 对绝对路径不做词法检查","severity":3,"scope":1,"evidence":"局部 evidence 字符串","recommendation":"补测试"}`,
		"最终产物如下：",
		"```json",
		`{"name":"代码库侦察员","change_name":"207-后端文件管理基础能力","purpose":"汇总 execution 需要读取的文件和测试模式","status":0,"summary":"已核对当前提案范围","evidence":["STATE_PATH","CHANGE_PATH"],"findings":[{"title":"受保护路径缺少回归测试","severity":3,"scope":1,"evidence":"acceptance 要求保护路径拒绝","recommendation":"补 RPC 测试"}]}`,
		"```",
	}, "\n")
	data, err := extractCapturedMemberJSONObject(text, member, "207-后端文件管理基础能力")
	if err != nil {
		t.Fatal(err)
	}
	var result ParallelMemberResult
	if err := json.Unmarshal(data, &result); err != nil {
		t.Fatal(err)
	}
	if result.Name != member.Name || result.ChangeName != "207-后端文件管理基础能力" {
		t.Fatalf("captured artifact = %#v", result)
	}
	if len(result.Evidence) != 2 || len(result.Findings) != 1 {
		t.Fatalf("captured nested fragment instead of full artifact: %#v", result)
	}
}

// TestReadOnlyBoundaryDetailReportsStatusDelta verifies diagnostics name the offending path.
func TestReadOnlyBoundaryDetailReportsStatusDelta(t *testing.T) {
	detail := readOnlyBoundaryDetail(
		"1234567890abcdef",
		"M  docs/changes/demo/task.md\n",
		"abcdef1234567890",
		"M  docs/changes/demo/task.md\n?? mob4dspaw\n",
	)
	for _, want := range []string{"HEAD 1234567890ab -> abcdef123456", "新增/变更：?? mob4dspaw"} {
		if !strings.Contains(detail, want) {
			t.Fatalf("detail missing %q: %s", want, detail)
		}
	}
}

// TestStatusDeltaSummaryLimitsLargeOutput keeps workflow errors concise.
func TestStatusDeltaSummaryLimitsLargeOutput(t *testing.T) {
	var after []string
	for i := 0; i < 10; i++ {
		after = append(after, fmt.Sprintf("?? artifact-%02d", i))
	}
	summary := statusDeltaSummary("", strings.Join(after, "\n"))
	if !strings.Contains(summary, "artifact-00") || !strings.Contains(summary, "... 还有 2 项") || strings.Contains(summary, "artifact-09") {
		t.Fatalf("summary = %q, want first items and overflow count only", summary)
	}
}
